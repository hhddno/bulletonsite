{
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/bulle/:path*",
      "destination": "https://bulle-chatbot.vercel.app/api/:path*"
    }
  ],
  "redirects": [
    { "source": "/diapo", "destination": "/diapo/", "permanent": true },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "bulletonsite.com" }],
      "destination": "https://www.bulletonsite.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
