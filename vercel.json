{
  "buildCommand": null,
  "outputDirectory": ".",
  "redirects": [
    { "source": "/diapo", "destination": "/diapo/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
